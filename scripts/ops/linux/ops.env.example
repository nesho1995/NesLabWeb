# API monitoring
API_BASE_URL=http://127.0.0.1:5225
LATENCY_WARN_MS=2500
WEBHOOK_URL=

# Backup monitor
BACKUP_DIR=/var/backups/neslab
BACKUP_PATTERN=*.sql
MAX_AGE_HOURS=26

# Backup execution
MYSQLDUMP_PATH=mysqldump
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=neslab
DB_USER=neslab
DB_PASSWORD=
KEEP_DAYS=14
